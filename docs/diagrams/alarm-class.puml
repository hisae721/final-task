' データの追加・保存・削除・取得に特化した役割
class AlarmDataManager {
    - storage: LocalStorageManager;

    ' アラームのデータを保存する為(重複禁止や最大件数も)のメソッド ↓↓↓↓↓↓
    + saveAll(alarms: Alarm[]): void
    + loadAll(): Alarm[]

    ' アラームのデータを全件削除する為のメソッド ↓↓↓↓↓↓
    + resetAll(): Alarm[]
    ' 下記１行は保存前の各処理⇩⇩
    ' - this.alarms = [];
    ' - this.persistToStorage();
    ' アラームのデータを１件削除する為のメソッド ↓↓↓↓↓↓
    + delete(id: string): void
    ' { 下記１行は保存前の各処理⇩⇩
    ' - alarms.filter()
    ' 丸ごと上書き保存 ⇩⇩⇩
    ' - this.persistToStorage()
    ' }

    ' 永続的に保存する 共通メソッド 
    ' - persistToStorage(): void
    ' { this.storage.saveAlarmData(this.alarms)}
}

' 「保存」と「読み取り」のみの役割(永続化管理)
class LocalStorageManager {
    + saveAlarmData(key: string, data: string): void
    + loadAlarmData(key: string): string | null
}

