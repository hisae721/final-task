' **列挙型**

enum AlarmState {
    ' アラームOFF
    DISABLED
    ' アラームONで待機(=WAITING)
    ENABLED
    ' 音が鳴る
    RINGING
}

enum ButtonType {
    ADD
    EDIT
    SAVE
    DELETE
    CLEAR
    CANCEL
}

' **インターフェース**

interface IDisplay {
    + renderInitial(): void;
    + renderAdd(onSave: () => void): void
    + renderRule(massage: string):void
    + renderAlertDialog(alarm: Alarm): void
    + renderMissedAlarm(): void;
    + renderList(alarms: Alarm[], selectedIds: Set<string>)
}

interface ISoundPlayer {
    - audio: HTMLAudioElement | null;
    + startSound(): void
    + stopSound(): void
}

